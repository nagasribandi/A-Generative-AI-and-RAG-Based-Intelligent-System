# EmailJS Configuration for Smart Campus Detection System
# Copy this file to .env and fill in your values
# OR set these as Environment Variables in Vercel Dashboard

REACT_APP_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here
REACT_APP_EMAILJS_SERVICE_ID=your_emailjs_service_id_here
REACT_APP_EMAILJS_TEMPLATE_OTP=template_otp
REACT_APP_EMAILJS_TEMPLATE_URGENT=template_urgent

# Google Gemini AI Configuration
# Get your free API key at: https://aistudio.google.com/app/apikey
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here
